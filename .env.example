# Copy to .env and fill in. .env is git-ignored (never commit real secrets).

# Discord webhook for restock alerts.
# Create one in your Discord server: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Optional email alerts (leave EMAIL_ENABLED=false to skip).
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
