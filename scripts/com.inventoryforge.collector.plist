<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd job: run the collector every 20 minutes.
  Install:
    cp scripts/com.inventoryforge.collector.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.inventoryforge.collector.plist
  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.inventoryforge.collector.plist
  Tail the log:
    tail -f "<repo>/collector.log"
  NOTE: the absolute paths below assume the repo lives where it is now. If you move
  the repo, update the two <string> paths and reload the job.
  IMPORTANT (macOS): launchd cannot run this if the repo is under Desktop/Documents/
  Downloads/iCloud/OneDrive without Full Disk Access — it fails "Operation not permitted".
  See README "Scheduling" for the fix (move the repo, or grant Full Disk Access to /bin/bash).
-->

<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.inventoryforge.collector</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/michaeljacinto/Library/CloudStorage/OneDrive-Personal/Desktop - onedrive/github/inventoryforge/scripts/run_collector.sh</string>
  </array>
  <!-- Times are LOCAL (Pacific). Morning sweep every 30 min 8:45-11:45 (when restocks land),
       then afternoon + evening checks. NOT every 15 min on purpose: a full run takes ~7-8
       min, so 15-min spacing would leave almost no gap, and rapid-fire polling already got
       us Cloudflare-throttled once. Add/remove <dict> entries to change the times. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>45</integer></dict>
    <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>15</integer></dict>
    <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>45</integer></dict>
    <dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>15</integer></dict>
    <dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>45</integer></dict>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>15</integer></dict>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>45</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key>
  <string>/Users/michaeljacinto/Library/CloudStorage/OneDrive-Personal/Desktop - onedrive/github/inventoryforge/collector.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/michaeljacinto/Library/CloudStorage/OneDrive-Personal/Desktop - onedrive/github/inventoryforge/collector.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
